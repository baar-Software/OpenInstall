# Normalize text to LF in the repo; let Git handle working-tree EOL.
* text=auto eol=lf

# Binary assets - never apply EOL conversion.
*.png  binary
*.ico  binary
*.icns binary
*.jpg  binary
*.exe  binary
*.msi  binary

# Package and signature fixtures are byte-exact.
*.oip      binary
*.minisig  binary
*.key      binary
*.pub      -text
